{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/.codex/hooks/lint-on-edit.cjs\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel 2>$null; if (-not $root) { $root = (Get-Location).Path }; node (Join-Path $root '.codex/hooks/lint-on-edit.cjs')\"",
            "statusMessage": "Running edit hook"
          }
        ]
      }
    ]
  }
}
