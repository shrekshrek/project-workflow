# scaffold-v2 环境变量样板
# 复制为 .env 后填实际值:`cp .env.example .env`
#
# .env 已加 .gitignore,绝不要提交

# === 项目隔离(docker-compose 官方识别的 env 名,影响容器 / 卷 / 网络前缀)===
# 默认从目录名推导(scaffold-v2),多项目并行时改成独有的名避免冲突
# COMPOSE_PROJECT_NAME=scaffold-v2

# === Postgres ===
POSTGRES_USER=app
POSTGRES_PASSWORD=app_dev_password
POSTGRES_DB=app
POSTGRES_PORT=5432

# === Backend ===
BACKEND_PORT=8000
JWT_SECRET=dev_only_change_in_prod_must_be_random_32_chars_or_more
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000/api/v1

# === Tier 2 邮件验证(暂不启用,留位见 docs/proposals/email-verification.md)===
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=false
