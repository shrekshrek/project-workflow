        </mxCell>
        <mxCell id="pillar_62" value="&lt;b&gt;§6.2 Context Budget&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;AGENTS.md 行数纪律 + @imports + 小 skill&lt;br/&gt;主服务:② Context&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="445" y="815" width="395" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="pillar_63" value="&lt;b&gt;§6.3 Env-Enforced Rules&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;hooks 把 review 自动化、不依赖人类记得&lt;br/&gt;主服务:③ Drift (实时)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="815" width="395" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="pillar_64" value="&lt;b&gt;§6.4 Three-Layer Review&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;按规则源分层 L1 / L2 / L3 — 正交不互感&lt;br/&gt;主服务:① Verification + ③ Drift (端点)&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#455A64;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1255" y="815" width="385" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="doc_header" value="文档物理位置(代码组织维度)— 5 类正交职责  &lt;span style=&#39;font-weight:normal;font-size:10px;color:#78909C;&#39;&gt;(↑ phase lanes 产出框中的 [A] [B] [C] [D] 标签对应前 4 类;[E] docs/current/&amp;lt;area&amp;gt;.md 产品事实由交付后 /feature-archive 创建维护,不在 P0 lane)&lt;/span&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=2;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="40" y="905" width="1620" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="doc_a" value="&lt;b&gt;A · 约定 (Conventions)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;AGENTS.md (项目/tier/模块 3 层嵌套) + path-scoped rules (Claude: .claude/rules/*.md) + adapter alias&lt;br/&gt;时间维度:&lt;b&gt;当前态&lt;/b&gt; — 我们现在怎么工作?&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="930" width="395" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="doc_b" value="&lt;b&gt;B · 任务 (Specs)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;docs/specs/&lt;NNN&gt;-&lt;slug&gt;/{spec, plan, tasks}.md&lt;br/&gt;时间维度:&lt;b&gt;per-feature 生命周期&lt;/b&gt; — 这个 feature 做什么 + 怎么做 + 步骤?&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="445" y="930" width="395" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="doc_c" value="&lt;b&gt;C · 决策 (ADR)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;docs/adr/NNNN-&lt;title&gt;.md  (扁平,不嵌套)&lt;br/&gt;时间维度:&lt;b&gt;时间戳快照,append-only&lt;/b&gt; — 当时为什么这么选?trade-off?&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="930" width="395" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="doc_d" value="&lt;b&gt;D · 工具基础设施 (Infra)&lt;/b&gt;&lt;br/&gt;&lt;span style=&#39;font-size:10px;&#39;&gt;.claude/{hooks, settings.json} + .gitignore&lt;br/&gt;时间维度:&lt;b&gt;跟项目演化&lt;/b&gt; — 工具自动跑什么?&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=11;align=left;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1255" y="930" width="385" height="75" as="geometry"/>
